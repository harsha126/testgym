{
  "permissions": {
    "allow": [
      "Bash(mvn clean *)",
      "Bash(docker build *)",
      "Bash(docker exec *)",
      "Bash(docker cp *)",
      "Bash(unzip -p /tmp/app.jar BOOT-INF/classes/com/gym/controller/CsvController.class)",
      "Bash(curl -v -u \"$CSV_USERNAME:$CSV_PASSWORD\" -X DELETE http://localhost:8080/api/csv/reset)",
      "Bash(curl -u \"$CSV_USERNAME:$CSV_PASSWORD\" -X POST -s -o /dev/null -w \"import: %{http_code}\\\\n\" http://localhost:8080/api/csv/import)",
      "Bash(curl -u \"$CSV_USERNAME:$CSV_PASSWORD\" -X DELETE -s -o /dev/null -w \"reset: %{http_code}\\\\n\" http://localhost:8080/api/csv/reset)",
      "Bash(curl -u \"$CSV_USERNAME:$CSV_PASSWORD\" -X GET -s -o /dev/null -w \"get-import: %{http_code}\\\\n\" http://localhost:8080/api/csv/import)",
      "Bash(curl -u \"$TEST_BAD_USERNAME:$TEST_BAD_PASSWORD\" -X POST -s -o /dev/null -w \"wrong: %{http_code}\\\\n\" http://localhost:8080/api/csv/import)",
      "Bash(curl -X POST -s -o /dev/null -w \"noauth: %{http_code}\\\\n\" http://localhost:8080/api/csv/import)",
      "Bash(curl -u \"$CSV_USERNAME:$CSV_PASSWORD\" -X POST -s -o /dev/null -w \"right: %{http_code}\\\\n\" http://localhost:8080/api/csv/import)"
    ]
  }
}
